# ═══════════════════════════════════════════════════════════════
# Variables de entorno para Payments App
# ═══════════════════════════════════════════════════════════════

# MercadoPago (obtener en https://www.mercadopago.com.ar/developers)
MP_ACCESS_TOKEN=TEST-xxxx

# URLs de las otras apps (Buyer, Seller, Shipping)
NEXT_PUBLIC_BUYER_APP_URL=http://localhost:3001
NEXT_PUBLIC_SELLER_APP_URL=http://localhost:3002
NEXT_PUBLIC_SHIPPING_APP_URL=http://localhost:3003

# URL de este proyecto (cambiar en producción)
NEXT_PUBLIC_URL=http://localhost:3000

# Clerk Authentication (obtener en https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Base de datos PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# OpenRouteService API (para cálculo de costos de envío)
# Obtener clave en https://openrouteservice.org/dev/#/login
ORS_API_KEY=your_ors_api_key_here